# JWT (required for auth)
JWT_SECRET=dev_secret_change_me

# MySQL — used by Prisma (`prisma.config.ts` loads this via dotenv)
# Docker: from repo root run `docker compose up -d` (see docker-compose.yml)
# Example: mysql://USER:PASSWORD@127.0.0.1:3306/DATABASE_NAME
DATABASE_URL="mysql://root:devroot@127.0.0.1:3306/longenyx"

# Cloudinary — https://cloudinary.com/console
# Dashboard shows Cloud name, API Key, API Secret
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: subfolder for uploads (default: healthcare-products)
# CLOUDINARY_FOLDER=healthcare-products

# Email (optional). none = log only; brevo = Brevo transactional API
EMAIL_PROVIDER=none
BREVO_API_KEY=
EMAIL_FROM_EMAIL=
EMAIL_FROM_NAME=P&P Sehran
# Optional login link base for patient welcome emails (no trailing slash required)
APP_PUBLIC_URL=http://localhost:5173
