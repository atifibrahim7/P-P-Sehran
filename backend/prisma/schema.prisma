datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  practitioner Practitioner?
  patient      Patient?
}

model Practitioner {
  id        Int    @id @default(autoincrement())
  userId    Int    @unique
  user      User   @relation(fields: [userId], references: [id])

  patients  Patient[]
  orders    Order[]
  commissions Commission[]
  carts     Cart[]
}

model Patient {
  id                        Int           @id @default(autoincrement())
  userId                    Int           @unique
  practitionerId            Int?
  title                     String?       @db.VarChar(10)
  forenames                 String        @db.VarChar(100)
  surname                   String        @db.VarChar(100)
  dateOfBirth               DateTime      @db.Date
  gender                    PatientGender
  policyNumber              String        @unique @db.VarChar(100)
  clientReference2          String?       @db.VarChar(100)
  nationalInsuranceNumber   String?       @db.VarChar(50)
  smokerStatus              SmokerStatus  @default(UNKNOWN)
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  user           User   @relation(fields: [userId], references: [id])
  practitioner   Practitioner? @relation(fields: [practitionerId], references: [id])

  orders         Order[]
  carts          Cart[]
  addresses      Address[]
  contacts       Contact[]
}

model Address {
  id            Int       @id @default(autoincrement())
  patientId     Int
  addressTypeId Int
  addressLine1  String    @db.VarChar(255)
  addressLine2  String?   @db.VarChar(255)
  addressLine3  String?   @db.VarChar(255)
  city          String    @db.VarChar(100)
  county        String?   @db.VarChar(100)
  country       String    @db.VarChar(100)
  postcode      String    @db.VarChar(20)
  isPreferred   Boolean   @default(false)
  createdAt     DateTime  @default(now())

  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model Contact {
  id          Int       @id @default(autoincrement())
  patientId   Int
  phoneNumber String    @db.VarChar(20)
  phoneType   PhoneType
  createdAt   DateTime  @default(now())

  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model Vendor {
  id      Int     @id @default(autoincrement())
  name    String
  type    VendorType

  products Product[]
}

model Product {
  id                  Int    @id @default(autoincrement())
  name                String
  description         String?
  category            ProductCategory
  vendorId            Int
  patientPrice        Float
  practitionerPrice   Float
  labTestCode         String?
  imageUrl            String?
  shopifyHandle       String? @db.VarChar(255)
  shopifyProductId    String? @db.VarChar(64)
  shopifyVariantId    String? @db.VarChar(64)

  vendor              Vendor @relation(fields: [vendorId], references: [id])
  orderItems          OrderItem[]
  cartItems           CartItem[]
  productImages       ProductImage[]
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  url       String  @db.VarChar(512)
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Cart {
  id               Int       @id @default(autoincrement())
  /** Null when scope is PATIENT_DIRECT (standalone patient ordering) */
  practitionerId   Int?
  scope            CartScope
  patientId        Int?
  updatedAt        DateTime  @updatedAt

  practitioner     Practitioner? @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  patient            Patient?     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  items              CartItem[]

  @@index([practitionerId, scope, patientId])
}

model CartItem {
  id        Int             @id @default(autoincrement())
  cartId    Int
  productId Int
  quantity  Int             @default(1)
  addedBy   CartItemSource
  labTestCategory LabTestCategory?

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

enum CartScope {
  SELF
  PATIENT
  PATIENT_DIRECT
}

enum CartItemSource {
  PRACTITIONER
  PATIENT
}

enum LabTestCategory {
  HOME_KIT
  LAB_VISIT
  PHLEBOTOMY
}

model Order {
  id             Int      @id @default(autoincrement())
  patientId      Int?
  practitionerId Int?
  type           OrderType
  totalAmount    Float

  status         OrderStatus @default(PENDING)
  paymentStatus  PaymentStatus @default(PENDING)
  createdAt      DateTime @default(now())

  patient        Patient? @relation(fields: [patientId], references: [id])
  practitioner   Practitioner? @relation(fields: [practitionerId], references: [id])

  items          OrderItem[]
  commission     Commission?
  testResult     TestResult?
}

model OrderItem {
  id                 Int   @id @default(autoincrement())
  orderId            Int
  productId          Int
  quantity           Int   @default(1)

  patientPrice       Float
  practitionerPrice  Float

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

enum CommissionPayoutStatus {
  PENDING
  PAID
}

model Commission {
  id             Int                     @id @default(autoincrement())
  practitionerId Int
  orderId        Int                     @unique
  amount         Float
  payoutStatus   CommissionPayoutStatus  @default(PENDING)

  practitioner Practitioner @relation(fields: [practitionerId], references: [id])
  order        Order @relation(fields: [orderId], references: [id])
}

model TestResult {
  id        Int    @id @default(autoincrement())
  orderId   Int    @unique
  reportUrl String
  status    String
  summary   String?

  order Order @relation(fields: [orderId], references: [id])
}

enum Role {
  ADMIN
  PRACTITIONER
  PATIENT
}

enum VendorType {
  LAB
  SUPPLEMENT
  BOTH
}

enum ProductCategory {
  BLOOD_TEST
  SUPPLEMENT
}

enum OrderType {
  SELF
  PATIENT
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
}

enum PatientGender {
  UNKNOWN
  MALE
  FEMALE
}

enum SmokerStatus {
  UNKNOWN
  NON_SMOKER
  SMOKER
}

enum PhoneType {
  MOBILE
  HOME
  WORK
  OTHER
}